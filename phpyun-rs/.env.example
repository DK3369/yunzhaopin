# Copy to .env and fill in real values
BIND=0.0.0.0:3000
APP_ENV=dev
RUST_LOG=info,phpyun_handlers=debug

# MySQL - shares the same database with the PHP side
DATABASE_URL=mysql://phpyun:CHANGE_ME@127.0.0.1:3306/phpyun

# Redis
REDIS_URL=redis://127.0.0.1/0

# JWT — generate the secret with `openssl rand -hex 32`. Repeated/placeholder
# values are rejected at startup. Min length 32 chars.
JWT_SECRET=CHANGE_ME_TO_RANDOM_32_BYTES
# Single-token sliding-session: client stores only the access_token; the app
# calls /refresh on launch (and before expiry) to rotate it. 30d ceiling.
JWT_ACCESS_TTL_SECS=2592000
JWT_REFRESH_TTL_SECS=2592000

# CORS — comma-separated origin whitelist. `*` is allowed in dev only;
# APP_ENV=prod will refuse to start with `*` or empty. Example for prod:
#   CORS_ALLOWED_ORIGINS=https://app.example.com,https://m.example.com
CORS_ALLOWED_ORIGINS=*

# WeChat Official Account webhook (leave empty and /wechat/callback returns 503)
WECHAT_TOKEN=
# Default welcome message (override in your env; the empty fallback uses the i18n key `wechat.welcome_default`)
WECHAT_WELCOME_MESSAGE=

# WeChat Official Account OAuth (snsapi_base) - /oauth/wechat/*
WECHAT_APPID=
WECHAT_APPSECRET=
WECHAT_OAUTH_REDIRECT=
